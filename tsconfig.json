{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@/*": ["./src/*"],
      "next/*": ["./node_modules/vinext/dist/shims/*"],
      "next/headers": ["./node_modules/vinext/dist/shims/headers"]
    }
  },
  "include": ["src", "*.ts"],
  "exclude": ["vitest.config.ts", "src/**/*.test.ts"]
}
